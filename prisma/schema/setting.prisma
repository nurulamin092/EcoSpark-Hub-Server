enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model Setting {
  id          String      @id @default(uuid())
  key         String      @unique
  value       Json?
  type        SettingType
  description String?
  isPublic    Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
