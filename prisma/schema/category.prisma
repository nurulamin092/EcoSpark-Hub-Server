model Category {
  id           String  @id @default(uuid())
  name         String  @unique
  slug         String  @unique
  description  String?
  icon         String?
  color        String?
  isActive     Boolean @default(true)
  isPredefined Boolean @default(false)
  order        Int     @default(0)

  ideas Idea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
  @@map("categories")
}
